# Kopiera till .env och fyll i värdena
# DELA ALDRIG .env i Git — den är redan med i .gitignore

# ── Databas ──────────────────────────────────────────────
POSTGRES_DB=terafalk
POSTGRES_USER=terafalk
POSTGRES_PASSWORD=byt_ut_detta_till_ett_starkt_losenord

# ── Applikation ───────────────────────────────────────────
# Generera med: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generera_med_kommandot_ovan
ENCRYPTION_KEY=generera_med_kommandot_ovan_annan_nyckel

# ── Microsoft Graph (utskick) ─────────────────────────────
# Azure Entra ID -> App registrations -> din app -> Overview
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
# Azure Entra ID -> App registrations -> din app -> Certificates & secrets
GRAPH_CLIENT_SECRET=
GRAPH_SENDER=noreply@terafalk.com

# ── Första admin-användare (skapas vid första start) ──────
FIRST_ADMIN_EMAIL=admin@terafalk.com
FIRST_ADMIN_PASSWORD=byt_genast_efter_forsta_inloggning
