# =============================================================================
# Insight – Miljökonfiguration
# =============================================================================
# Kopiera den här filen till .env och fyll i värdena:
#   cp .env.example .env
#
# VIKTIGT: Lägg aldrig .env under versionshantering (git). Filen innehåller
# hemligheter som API-nycklar och lösenord.
# =============================================================================


# -----------------------------------------------------------------------------
# PostgreSQL-databas
# -----------------------------------------------------------------------------
# Används av både "db"-containern och "backend"-containern.
# Välj valfria namn/lösenord — de behöver bara matcha varandra.

POSTGRES_DB=insight
POSTGRES_USER=insight
POSTGRES_PASSWORD=BYTA_TILL_STARKT_LOSENORD


# -----------------------------------------------------------------------------
# Driftläge
# -----------------------------------------------------------------------------
# "production" tvingar fram säkra hemligheter — appen vägrar starta med
# standardvärden för SECRET_KEY, ENCRYPTION_KEY eller FIRST_ADMIN_PASSWORD.
# Använd "development" lokalt.

ENVIRONMENT=production


# -----------------------------------------------------------------------------
# App-säkerhet
# -----------------------------------------------------------------------------

# JWT-signeringsnyckel — används för att signera och verifiera inloggnings-
# tokens. Om denna läcker kan angripare förfalska inloggningar.
# Generera med:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=BYTA_TILL_SLUMPMASSIG_STRANG

# Fernet-krypteringsnyckel — används för att kryptera API-nycklar i databasen.
# Måste vara en giltig 44-tecken Fernet-nyckel (URL-safe base64, 32 bytes).
# Generera med:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# VARNING: Om du byter nyckel kan inte befintliga krypterade credentials
# läsas. Byt bara nyckel vid ny installation eller med planerad migrering.
ENCRYPTION_KEY=BYTA_TILL_FERNET_NYCKEL

# Tillåtna CORS-origins (kommaseparerade).
# Sätt till din faktiska domän i produktion — aldrig * i produktion.
# Exempel: https://insight.terafalk.com
# Exempel med flera: https://insight.terafalk.com,https://staging.terafalk.com
ALLOWED_ORIGINS=https://insight.terafalk.com


# -----------------------------------------------------------------------------
# Första administratörskontot
# -----------------------------------------------------------------------------
# Skapas automatiskt vid första uppstart om det inte redan finns.
# Byt lösenord direkt efter första inloggning.

FIRST_ADMIN_EMAIL=admin@terafalk.com
FIRST_ADMIN_PASSWORD=BYTA_OMEDELBART


# -----------------------------------------------------------------------------
# Microsoft Graph — TERAFALK:s avsändar-app (e-post)
# -----------------------------------------------------------------------------
# Används för att skicka rapporter via e-post från noreply@terafalk.com.
# Registrera en single-tenant app i Azure AD (TERAFALK:s tenant) med
# behörigheten: Mail.Send (Application).
#
# Azure Portal → App registrations → [din app] → Certificates & secrets

GRAPH_TENANT_ID=               # TERAFALK:s tenant-ID (GUID)
GRAPH_CLIENT_ID=               # App (client) ID för avsändar-appen
GRAPH_CLIENT_SECRET=           # Client secret för avsändar-appen
GRAPH_SENDER=noreply@terafalk.com

# Bas-URL till portalen — används för länkar i utgående mejl (t.ex. "Öppna ärendet").
# Lämna tom för att utelämna knapparna.
PORTAL_URL=https://insight.terafalk.com


# -----------------------------------------------------------------------------
# Microsoft 365 kundintegration — multi-tenant app
# -----------------------------------------------------------------------------
# Används för att hämta data från kunders Microsoft 365-tenants via
# admin consent-flöde (OAuth 2.0 client credentials).
#
# Registrera en multi-tenant app i Azure AD med följande
# Application-behörigheter (inte delegerade):
#   - Organization.Read.All
#   - User.Read.All
#   - UserAuthenticationMethod.Read.All
#   - AuditLog.Read.All
#   - Reports.Read.All
#   - RoleManagement.Read.Directory
#   - DeviceManagementManagedDevices.Read.All
#   - SecurityEvents.Read.All (för Secure Score)
#
# Redirect URI måste registreras i appen:
#   https://<din-domän>/api/auth/microsoft/callback

MS_APP_CLIENT_ID=              # App (client) ID för kundintegrationsappen
MS_APP_CLIENT_SECRET=          # Client secret för kundintegrationsappen
MS_APP_REDIRECT_URI=https://insight.terafalk.com/api/auth/microsoft/callback


# -----------------------------------------------------------------------------
# Rapport-output (valfritt — Docker volume används som standard)
# -----------------------------------------------------------------------------
# Sökväg inuti backend-containern dit genererade PDF-rapporter sparas.
# Ändra bara om du monterar en extern volym på annan sökväg.

# REPORTS_OUTPUT_DIR=/app/reports_output
